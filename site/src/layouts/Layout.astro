---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Cyber Knights FRC',
	description = 'Official website for the Cyber Knights FIRST Robotics Competition team.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg: #06161b;
		--bg-soft: #0d252e;
		--surface: #113745;
		--line: #1e5669;
		--text: #f2f8fb;
		--muted: #b2cdda;
		--accent: #ff7a18;
		--accent-soft: #ffc48f;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		font-family: 'Avenir Next', 'Trebuchet MS', sans-serif;
		background:
			radial-gradient(circle at 5% 5%, rgba(255, 122, 24, 0.12), transparent 35%),
			radial-gradient(circle at 90% 10%, rgba(85, 184, 214, 0.16), transparent 40%),
			linear-gradient(150deg, var(--bg), #081f28 42%, #031117);
		color: var(--text);
		min-height: 100%;
	}

	a {
		color: inherit;
		text-decoration: none;
	}
</style>
